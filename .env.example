# Copy to .env and fill in your values.
# Provider API keys keep their standard names (the provider SDKs read them
# directly); agent-specific settings use the AGENT_ prefix to avoid clashing
# with generic shell variables like MODEL.

# Required when AGENT_MODEL is an Anthropic model (default)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required when AGENT_MODEL is an OpenAI model
# OPENAI_API_KEY=your_openai_api_key_here

# Model selection (default: anthropic:claude-opus-4-8)
# AGENT_MODEL=anthropic:claude-opus-4-8
# AGENT_MODEL=anthropic:claude-sonnet-5
# AGENT_MODEL=ollama:llama3.3            # local Ollama — no API key required

# Judge model for LLM-as-judge evals (default: anthropic:claude-sonnet-5)
# AGENT_JUDGE_MODEL=anthropic:claude-sonnet-5

# Logfire observability (optional — console output used if not set)
# LOGFIRE_TOKEN=your_logfire_token_here

# Logging level (DEBUG, INFO, WARNING, ERROR)
AGENT_LOG_LEVEL=INFO
