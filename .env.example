# Copy to .env and fill in your values.
# Provider API keys keep their standard names (the provider SDKs read them
# directly); agent-specific settings use the AGENT_ prefix to avoid clashing
# with generic shell variables like MODEL.
#
# For the deployed GitHub Actions workflow, all of these live as repo secrets
# instead of a committed .env file — see README.md's "Fork this repo" section.

# Required when AGENT_MODEL is a Google model (default)
GOOGLE_API_KEY=your_google_api_key_here

# Required when AGENT_MODEL is an Anthropic model
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required when AGENT_MODEL is an OpenAI model
# OPENAI_API_KEY=your_openai_api_key_here

# Model selection (default: google:gemini-3.1-flash-lite)
# AGENT_MODEL=google:gemini-3.1-flash-lite
# AGENT_MODEL=anthropic:claude-opus-4-8
# AGENT_MODEL=anthropic:claude-sonnet-5
# AGENT_MODEL=ollama:llama3.3            # local Ollama — no API key required

# Judge model for LLM-as-judge evals (default: anthropic:claude-sonnet-5)
# AGENT_JUDGE_MODEL=anthropic:claude-sonnet-5

# Logfire observability (optional — console output used if not set)
# LOGFIRE_TOKEN=your_logfire_token_here

# Logging level (DEBUG, INFO, WARNING, ERROR)
AGENT_LOG_LEVEL=INFO

# --- GitHub Good-First-Issue Digest pipeline ---

# GitHub token for the Search API. In GitHub Actions this is provided
# automatically as GITHUB_TOKEN — only set this locally for manual testing.
# GITHUB_TOKEN=your_github_token_here

# Pipeline config: the repo watch list, as a YAML document (double-quoted,
# spanning multiple lines works fine, same as bash). Required. In production
# this same value is set as the AGENT_PIPELINE_CONFIG GitHub Secret instead.
#
# labels/search_terms are entirely optional, at both the defaults and
# per-repo level. Most repos don't label issues "good first issue" — leaving
# labels/search_terms unset sends every new, open, unassigned issue to the
# triage agent and lets it judge suitability from the issue text itself,
# which is the main reason to use an LLM for this instead of a plain label
# search. Only add labels/search_terms if you specifically want to pre-filter
# the search before triage runs (example further below).
#
# Remove the leading "# " from every line below to activate it:
# AGENT_PIPELINE_CONFIG="repositories:
#   - repo: owner/name
#   - repo: owner/another-name
# "
#
# Example of pre-filtering, for repos that DO label issues well and where you
# want to narrow the search before the LLM ever sees an issue:
# AGENT_PIPELINE_CONFIG="defaults:
#   labels: [good first issue, help wanted]
#   search_terms: [typo, documentation]
# repositories:
#   - repo: owner/name
#   - repo: owner/another-name
#     labels: [easy, starter]
#     search_terms: [css, typo]
# "

# Postmark email delivery
# POSTMARK_SERVER_TOKEN=your_postmark_server_token_here
# AGENT_EMAIL_FROM=digest@yourdomain.com
# AGENT_EMAIL_TO=you@example.com,teammate@example.com

# Pipeline tuning (all optional, defaults shown). AGENT_SEARCH_WINDOW_HOURS
# is not derived from notify.yml's cron schedule (default: daily) — if you
# change the cadence, update this to match (plus a small buffer).
# AGENT_SEARCH_WINDOW_HOURS=25
# AGENT_MAX_ISSUE_BODY_CHARS=4000
# AGENT_MAX_ISSUES_PER_RUN=30
